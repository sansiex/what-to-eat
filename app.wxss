/* app.wxss */
page, view, text, button, input, image, scroll-view, swiper, swiper-item {
  box-sizing: border-box;
}

page {
  background: #E8F5E9;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
}

.container {
  padding: 24rpx;
}

.section {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.btn {
  display: block;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.btn:active {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.input {
  width: 100%;
  padding: 20rpx 24rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  font-size: 32rpx;
  margin-bottom: 20rpx;
  background-color: #fff;
}

.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #C8E6C9;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item__content {
  flex: 1;
}

.list-item__title {
  font-size: 38rpx;
  margin-bottom: 8rpx;
  color: #1a1a1a;
  font-weight: 600;
}

.list-item__desc {
  font-size: 24rpx;
  color: #999;
}

.list-item__actions {
  display: flex;
  align-items: center;
}

/* 各页列表中的菜品缩略图：统一尺寸、略大圆角，配合各页收紧 padding 更醒目 */
/* 与文案间距：各页 flex gap / margin-left 建议 ≈ 136 + 28 = 164rpx 对齐文案左缘 */
.dish-list-thumb {
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.icon {
  width: 48rpx;
  height: 48rpx;
  margin-left: 16rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  margin-right: 16rpx;
}

.search-bar {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  color: #999;
}

.search-input {
  flex: 1;
  border: none;
  background-color: transparent;
  font-size: 32rpx;
  color: #1A1A1A;
}

.search-input:focus {
  outline: none;
}

.dialog {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.dialog-content {
  background-color: #fff;
  border-radius: 16rpx;
  width: 80%;
  max-width: 500rpx;
  padding: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 32rpx;
  text-align: center;
  color: #1A1A1A;
}

.dialog-actions {
  display: flex;
  justify-content: space-between;
  margin-top: 32rpx;
  gap: 16rpx;
}

.dialog-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 500;
}

.dialog-btn--cancel {
  background-color: #C8E6C9;
  color: #666;
}

.dialog-btn--confirm {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

/* 列表页：数据加载中（转圈 + 文案） */
.list-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx 80rpx;
  gap: 28rpx;
}

.list-loading--inline {
  flex-direction: row;
  padding: 28rpx 16rpx 36rpx;
  gap: 20rpx;
  justify-content: center;
}

.list-loading--compact {
  flex-direction: row;
  padding: 40rpx 24rpx;
  gap: 20rpx;
  justify-content: center;
}

.list-loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e8f5e9;
  border-top-color: #66bb6a;
  border-radius: 50%;
  animation: list-loading-spin 0.75s linear infinite;
}

.list-loading-spinner--sm {
  width: 36rpx;
  height: 36rpx;
  border-width: 3rpx;
}

@keyframes list-loading-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.list-loading-text {
  font-size: 28rpx;
  color: #888;
}
