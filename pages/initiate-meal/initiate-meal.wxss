/* pages/initiate-meal/initiate-meal.wxss */

page {
  height: 100%;
  background: #E8F5E9;
}

/* 整页：上表单（含 picker，勿放 scroll-view 内）+ 中间滚动菜品 + 底栏 */
.page-initiate-meal {
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

/* 餐名、日期/时间选择器：固定在上部，避免 iOS 在 scroll-view 内 picker 空白 */
.initiate-meal-form-top {
  flex-shrink: 0;
  width: 100%;
}

.initiate-meal-scroll {
  flex: 1;
  height: 0;
  min-height: 0;
  width: 100%;
  box-sizing: border-box;
}

.initiate-meal-scroll-inner {
  padding-bottom: 8rpx;
}

.initiate-meal-body {
  padding-bottom: 8rpx;
}

.section--scroll {
  margin-bottom: 0;
}

/* 餐名 / 用餐时间 / 菜品选择 区块标题（略大于原 28rpx，便于扫读） */
.initiate-form-section-label {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

/* 用餐时间：与餐名、菜品选择同级，不再单独套一层色块框 */
.meal-schedule-section {
  margin-bottom: 24rpx;
}

.meal-schedule-picker-block {
  display: block;
  margin-bottom: 16rpx;
}

.meal-schedule-time-outer {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meal-schedule-picker-block--grow {
  flex: 1;
  min-width: 0;
  margin-bottom: 0;
}

.meal-schedule-row {
  display: flex;
  align-items: center;
  min-height: 80rpx;
  padding: 0 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1rpx solid #c8e6c9;
  box-sizing: border-box;
}

.meal-schedule-row__label {
  font-size: 28rpx;
  color: #666;
  width: 100rpx;
  flex-shrink: 0;
}

.meal-schedule-row__value {
  flex: 1;
  font-size: 28rpx;
  color: #000000;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meal-schedule-row__value--muted {
  color: #999;
}

.meal-schedule-row__arrow {
  margin-left: 12rpx;
  font-size: 32rpx;
  color: #bdbdbd;
  flex-shrink: 0;
}

.meal-schedule-clear {
  font-size: 26rpx;
  color: #2e7d32;
  flex-shrink: 0;
  padding: 8rpx 12rpx;
}

/* 底部操作栏：始终贴在视口下方 */
.initiate-meal-footer {
  flex-shrink: 0;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #C8E6C9;
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.06);
}

.initiate-meal-footer__btns {
  width: 100%;
}

.initiate-meal-footer__btns--row {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.btn--footer {
  margin-top: 0;
  width: 100%;
}

.initiate-meal-footer__btns--row .btn--footer {
  width: auto;
}

/* 仅「完成」单按钮时占满宽度 */
.initiate-meal-footer__btns .btn--footer-complete {
  width: 100%;
}

/* 编辑点餐：完成 = 绿底白字 + 勾选图标（返回使用导航栏左上角） */
.initiate-footer-btn-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
}

.initiate-meal-footer .btn--footer-complete {
  margin-top: 0;
  background: linear-gradient(135deg, #66bb6a 0%, #81c784 100%) !important;
  color: #fff !important;
  box-shadow: 0 4rpx 14rpx rgba(76, 175, 80, 0.28);
}

.initiate-meal-footer .btn--footer-complete::after {
  border: none;
}

.initiate-meal-footer .btn--footer-complete[disabled] {
  background: #c8e6c9 !important;
  color: #999 !important;
  box-shadow: none;
}


.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 240, 0.3);
}

.btn:active {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.btn[disabled] {
  background: #C8E6C9;
  color: #999;
  box-shadow: none;
}

button {
  background-color: #C8E6C9;
  color: #1A1A1A;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

button:active {
  background-color: #C8E6C9;
}

/* 餐名输入框 */
.meal-name-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
}

/* 已选数量 + 全选：与菜单编辑页 tab 工具条一致，全选为蓝色文字链 */
.initiate-select-toolbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
  gap: 16rpx;
}

.initiate-select-toolbar .selected-dish-count {
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
}

/* 与 menu-edit .section-action 一致 */
.initiate-meal-body .section-action {
  font-size: 26rpx;
  color: #007aff;
  flex-shrink: 0;
}

/* 已选菜品数 */
.selected-dish-count {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 16rpx;
}

/* 发起点餐页菜品列表 - 已选 / 未选 行区分 */
.dish-select-row {
  /* 右侧多留空：原生 checkbox 热区/绘制易略宽于 32rpx，避免超出卡片描边 */
  padding: 10rpx 22rpx 10rpx 12rpx;
  margin-bottom: 12rpx;
  border-radius: 14rpx;
  border-bottom: none;
  box-sizing: border-box;
}

/* list-item 仅有一个子节点时默认不占满宽，需拉满才能让勾选框靠最右 */
.dish-select-row.list-item > .dish-select-row__inner {
  flex: 1;
  min-width: 0;
}

.dish-select-row__inner {
  display: flex;
  align-items: center;
  gap: 28rpx;
}

.dish-select-row__text {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}

.dish-select-row__desc {
  margin-top: 6rpx;
}

/* 勾选框靠右但留在卡片内：由外层占位，避免 margin-left:auto 直接作用在原生组件上溢出 */
.dish-select-row__check-wrap {
  flex-shrink: 0;
  margin-left: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 40rpx;
  padding-left: 8rpx;
}

.dish-select-row__check {
  margin-right: 0 !important;
  margin-left: 0 !important;
  flex-shrink: 0;
}

.dish-select-row:last-child {
  margin-bottom: 0;
}

/* 已勾选：浅绿底 + 绿色描边 */
.dish-select-row--selected {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx solid #81C784;
  box-shadow: 0 2rpx 10rpx rgba(76, 175, 80, 0.15);
}

/* 未勾选：灰底 + 弱化文字 */
.dish-select-row--unselected {
  background: #EEEEEE;
  border: 2rpx solid #E0E0E0;
  opacity: 0.96;
}

.dish-select-row--unselected .list-item__title {
  color: #616161;
}

.dish-select-row--unselected .list-item__desc {
  color: #9E9E9E;
}

.dish-select-row--unselected image {
  opacity: 0.75;
}

/* 发起点餐页菜品列表 - 菜品名称字体加大 */
.dish-select-row .list-item__title {
  font-size: 40rpx;
}

.dish-select-row--selected .list-item__title {
  color: #1B5E20;
  font-weight: 600;
}

.dialog-content .input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 8rpx;
  background-color: #fff;
}
