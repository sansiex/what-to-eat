/* pages/initiate-meal/initiate-meal.wxss */

.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(91, 108, 240, 0.3);
}

.btn:active {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.btn[disabled] {
  background: #C8E6C9;
  color: #999;
  box-shadow: none;
}

button {
  background-color: #C8E6C9;
  color: #1A1A1A;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

button:active {
  background-color: #C8E6C9;
}

/* 餐名选择按钮样式 */
.meal-type-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 12rpx 24rpx;
  text-align: center;
  background-color: #C8E6C9;
  color: #1A1A1A;
  border-radius: 8rpx;
  font-weight: 500;
  border: none;
}

.meal-type-btn--active {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.dialog-content .input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 8rpx;
  background-color: #fff;
}
