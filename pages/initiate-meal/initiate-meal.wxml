<!-- pages/initiate-meal/initiate-meal.wxml -->
<view class="page-initiate-meal">
  <scroll-view scroll-y class="initiate-meal-scroll" enable-back-to-top="{{true}}">
    <view class="container initiate-meal-body">
      <view class="section section--scroll">
        <text class="dialog-title">{{isEditMode ? '编辑点餐' : '发起点餐'}}</text>
        
        <!-- 餐名输入 -->
        <view style="margin-bottom: 24rpx;">
          <text style="display: block; margin-bottom: 12rpx; font-size: 28rpx;">餐名</text>
          <input
            class="input meal-name-input"
            placeholder="请输入餐名（如：早餐、午餐）"
            bindinput="onMealNameInput"
            value="{{selectedMealName}}"
          />
        </view>

        <!-- 用餐时间：日期/时刻均为北京时间，见 AGENTS.md -->
        <view class="meal-schedule-section">
          <text class="meal-schedule-title">用餐时间</text>
          <picker class="meal-schedule-picker-block" mode="selector" range="{{mealDateLabels}}" value="{{mealDateIndex}}" bindchange="onMealDateChange">
            <view class="meal-schedule-row">
              <text class="meal-schedule-row__label">日期</text>
              <text class="meal-schedule-row__value">{{mealDateDisplay}}</text>
              <text class="meal-schedule-row__arrow">›</text>
            </view>
          </picker>
          <view class="meal-schedule-time-outer">
            <picker
              class="meal-schedule-picker-block meal-schedule-picker-block--grow"
              mode="multiSelector"
              range="{{mealTimeRange}}"
              value="{{mealTimePickerValue}}"
              bindchange="onMealTimeChange"
            >
              <view class="meal-schedule-row">
                <text class="meal-schedule-row__label">时间</text>
                <text class="meal-schedule-row__value">{{mealTimeDisplay}}</text>
                <text class="meal-schedule-row__arrow">›</text>
              </view>
            </picker>
            <text wx:if="{{mealTimeSpecified}}" class="meal-schedule-clear" catchtap="clearMealTime">清除</text>
          </view>
        </view>
        
        <!-- 菜品选择 -->
        <view>
          <text class="initiate-dish-select-label">菜品选择</text>

          <view wx:if="{{dishes.length === 0}}" style="padding: 40rpx 0; text-align: center; color: #999;">
            暂无菜品，请先在首页添加
          </view>

          <view wx:else>
            <view class="initiate-select-toolbar">
              <text class="selected-dish-count">已选 {{selectedDishes.length}} 道菜</text>
              <view class="section-action" bindtap="toggleSelectAll">{{selectAll ? '全不选' : '全选'}}</view>
            </view>
            <view 
              wx:for="{{dishes}}" 
              wx:key="{{item.id}}" 
              class="list-item dish-select-row {{item.selected ? 'dish-select-row--selected' : 'dish-select-row--unselected'}}"
            >
          <view class="dish-select-row__inner">
            <image
              class="dish-list-thumb"
              src="{{item.displayImage}}"
              mode="aspectFill"
              catchtap="previewDishImage"
              data-url="{{item.displayImage}}"
            />
            <view class="dish-select-row__text">
              <text class="list-item__title">{{item.name}}</text>
              <text class="list-item__desc dish-select-row__desc">{{item.displayDescription}}</text>
            </view>
            <view class="dish-select-row__check-wrap">
              <checkbox
                class="checkbox dish-select-row__check"
                value="{{item.id}}"
                checked="{{item.selected}}"
                bindtap="toggleDishSelection"
                data-id="{{item.id}}"
              />
            </view>
          </view>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>

  <!-- 底部固定操作区（相对视口底部，不随列表滚动） -->
  <view class="initiate-meal-footer">
    <view wx:if="{{isEditMode}}" class="initiate-meal-footer__btns">
      <button
        class="btn btn--footer btn--footer-complete"
        bindtap="completeEdit"
        disabled="{{!selectedMealName}}"
      >
        <view class="initiate-footer-btn-inner">
          <icon
            class="initiate-footer-btn-icon"
            type="success_no_circle"
            size="22"
            color="{{selectedMealName ? '#FFFFFF' : '#9E9E9E'}}"
          />
          <text>完成</text>
        </view>
      </button>
    </view>
    <button 
      wx:else
      class="btn btn--footer" 
      bindtap="initiateMeal"
      disabled="{{!selectedMealName || selectedDishes.length === 0}}">
      确认发起点餐
    </button>
  </view>
</view>
