<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 厨房选择栏 -->
  <view class="kitchen-bar" bindtap="showKitchenSelector">
    <text class="kitchen-name">{{currentKitchen.name || '我的厨房'}}</text>
    <text class="kitchen-arrow">▼</text>
  </view>

  <!-- 厨房选择下拉弹窗 -->
  <view class="kitchen-popup" wx:if="{{showKitchenPopup}}">
    <view class="kitchen-popup-mask" bindtap="hideKitchenSelector"></view>
    <view class="kitchen-popup-content">
      <!-- 创建厨房按钮 -->
      <view class="kitchen-popup-item create-kitchen" bindtap="showCreateKitchenDialog">
        <text class="create-kitchen-icon">+</text>
        <text class="create-kitchen-text">创建新厨房</text>
      </view>

      <!-- 厨房列表 -->
      <view
        wx:for="{{kitchens}}"
        wx:key="id"
        class="kitchen-popup-item {{item.id === currentKitchen.id ? 'active' : ''}}"
        bindtap="switchKitchen"
        data-id="{{item.id}}"
      >
        <text class="kitchen-item-name">{{item.name}}</text>
        <text wx:if="{{item.isDefault}}" class="kitchen-item-default">默认</text>
        <text wx:if="{{item.id === currentKitchen.id}}" class="kitchen-item-check">✓</text>
      </view>
    </view>
  </view>

  <!-- 创建厨房弹窗 -->
  <view class="dialog" wx:if="{{showCreateKitchenPopup}}">
    <view class="dialog-mask" bindtap="hideCreateKitchenDialog"></view>
    <view class="dialog-content">
      <view class="dialog-title">创建新厨房</view>
      <input
        class="dialog-input"
        placeholder="请输入厨房名称"
        value="{{newKitchenName}}"
        bindinput="onKitchenNameInput"
        focus="{{showCreateKitchenPopup}}"
      />
      <view class="dialog-buttons">
        <button class="dialog-btn btn-cancel" bindtap="hideCreateKitchenDialog">取消</button>
        <button class="dialog-btn btn-confirm" bindtap="createKitchen">确定</button>
      </view>
    </view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索菜品"
      bindinput="onSearch"
      value="{{searchKeyword}}"
    />
  </view>

  <!-- 菜品列表 -->
  <view class="section">
    <view class="section-header">
      <text style="font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 24rpx;">菜品清单</text>
      <view style="display: flex; gap: 16rpx; width: 100%;">
        <button
          class="header-btn"
          bindtap="showAddDialog"
        >
          添加菜品
        </button>
        <button
          class="header-btn"
          bindtap="navigateToInitiateMeal"
        >
          开始点菜
        </button>
      </view>
    </view>

    <view wx:if="{{filteredDishes.length === 0}}" style="padding: 40rpx 0; text-align: center; color: #999;">
      暂无菜品，请添加
    </view>

    <view wx:else>
      <view
        wx:for="{{filteredDishes}}"
        wx:key="{{item.id}}"
        class="list-item"
      >
        <view class="list-item__content">
          <text class="list-item__title">{{item.name}}</text>
        </view>
        <view class="list-item__actions">
          <button
            style="font-size: 24rpx; padding: 6rpx 12rpx; margin-right: 12rpx;"
            bindtap="showEditDialog"
            data-id="{{item.id}}"
          >
            编辑
          </button>
          <button
            style="font-size: 24rpx; padding: 6rpx 12rpx;"
            type="warn"
            bindtap="deleteDish"
            data-id="{{item.id}}"
          >
            删除
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加菜品弹窗 -->
  <view class="dialog" wx:if="{{showAddDialog}}">
    <view class="dialog-mask" bindtap="hideAddDialog"></view>
    <view class="dialog-content">
      <view class="dialog-title">添加菜品</view>
      <input
        class="dialog-input"
        placeholder="请输入菜品名称"
        value="{{newDishName}}"
        bindinput="onDishNameInput"
        focus="{{showAddDialog}}"
      />
      <view class="dialog-buttons">
        <button class="dialog-btn btn-cancel" bindtap="hideAddDialog">取消</button>
        <button class="dialog-btn btn-confirm" bindtap="addDish">确定</button>
      </view>
    </view>
  </view>

  <!-- 编辑菜品弹窗 -->
  <view class="dialog" wx:if="{{showEditDialog}}">
    <view class="dialog-mask" bindtap="hideEditDialog"></view>
    <view class="dialog-content">
      <view class="dialog-title">编辑菜品</view>
      <input
        class="dialog-input"
        placeholder="请输入菜品名称"
        value="{{editingDishName}}"
        bindinput="onDishNameInput"
        focus="{{showEditDialog}}"
      />
      <view class="dialog-buttons">
        <button class="dialog-btn btn-cancel" bindtap="hideEditDialog">取消</button>
        <button class="dialog-btn btn-confirm" bindtap="updateDish">确定</button>
      </view>
    </view>
  </view>
</view>
