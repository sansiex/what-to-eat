<!-- pages/index/index.wxml -->
<view class="container">
  <!-- 厨房标题栏 -->
  <view class="kitchen-bar">
    <text class="kitchen-name">我的厨房</text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索菜品"
      bindinput="onSearch"
      value="{{searchKeyword}}"
    />
  </view>

  <!-- 菜品列表 -->
  <view class="section">
    <view class="section-header">
      <text style="font-size: 32rpx; font-weight: 600; display: block; margin-bottom: 24rpx;">菜品清单</text>
      <view style="display: flex; gap: 16rpx; width: 100%;">
        <button
          class="header-btn"
          bindtap="showAddDialog"
        >
          添加菜品
        </button>
        <button
          class="header-btn"
          bindtap="navigateToInitiateMeal"
        >
          发起点菜
        </button>
      </view>
    </view>

    <view wx:if="{{filteredDishes.length === 0}}" style="padding: 40rpx 0; text-align: center; color: #999;">
      暂无菜品，请添加
    </view>

    <view wx:else>
      <view
        wx:for="{{filteredDishes}}"
        wx:key="id"
        class="list-item"
      >
        <view class="list-item__content">
          <text class="list-item__title">{{item.name}}</text>
        </view>
        <view class="list-item__actions">
          <button
            style="font-size: 24rpx; padding: 6rpx 12rpx; margin-right: 12rpx;"
            bindtap="showEditDialog"
            data-id="{{item.id}}"
          >
            编辑
          </button>
          <button
            style="font-size: 24rpx; padding: 6rpx 12rpx;"
            type="warn"
            bindtap="deleteDish"
            data-id="{{item.id}}"
          >
            删除
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 添加菜品弹窗 -->
  <view class="dialog" wx:if="{{showAddDialog}}">
    <view class="dialog-mask" bindtap="hideAddDialog"></view>
    <view class="dialog-content">
      <view class="dialog-title">添加菜品</view>
      <input
        class="input"
        placeholder="请输入菜品名称"
        value="{{newDishName}}"
        bindinput="onDishNameInput"
        focus="{{showAddDialog}}"
      />
      <view class="dialog-actions">
        <button class="dialog-btn dialog-btn--cancel" bindtap="hideAddDialog">取消</button>
        <button class="dialog-btn dialog-btn--confirm" bindtap="addDish">确定</button>
      </view>
    </view>
  </view>

  <!-- 编辑菜品弹窗 -->
  <view class="dialog" wx:if="{{showEditDialog}}">
    <view class="dialog-mask" bindtap="hideEditDialog"></view>
    <view class="dialog-content">
      <view class="dialog-title">编辑菜品</view>
      <input
        class="input"
        placeholder="请输入菜品名称"
        value="{{editingDishName}}"
        bindinput="onDishNameInput"
        focus="{{showEditDialog}}"
      />
      <view class="dialog-actions">
        <button class="dialog-btn dialog-btn--cancel" bindtap="hideEditDialog">取消</button>
        <button class="dialog-btn dialog-btn--confirm" bindtap="updateDish">确定</button>
      </view>
    </view>
  </view>
</view>
