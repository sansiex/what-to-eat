/* pages/index/index.wxss */

/* 厨房选择栏 */
.kitchen-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.kitchen-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-right: 12rpx;
}

.kitchen-arrow {
  font-size: 24rpx;
  color: #fff;
}

/* 厨房下拉弹窗 */
.kitchen-popup {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.kitchen-popup-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.4);
}

.kitchen-popup-content {
  position: absolute;
  top: 160rpx;
  left: 30rpx;
  right: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
  max-height: 600rpx;
  overflow-y: auto;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.kitchen-popup-item {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #C8E6C9;
}

.kitchen-popup-item:last-child {
  border-bottom: none;
}

.kitchen-popup-item.active {
  background-color: #C8E6C9;
}

.kitchen-popup-item.create-kitchen {
  background: #C8E6C9;
  border-radius: 16rpx 16rpx 0 0;
}

.create-kitchen-icon {
  font-size: 36rpx;
  font-weight: 600;
  color: #666;
  margin-right: 16rpx;
}

.create-kitchen-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
}

.kitchen-item-name {
  flex: 1;
  font-size: 30rpx;
  color: #1A1A1A;
}

.kitchen-item-default {
  font-size: 22rpx;
  color: #999;
  background-color: #C8E6C9;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.kitchen-item-check {
  font-size: 28rpx;
  color: #666;
  font-weight: 600;
}

.section-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.header-btn {
  flex: 1;
  min-width: 0;
  max-width: 50%;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 8rpx rgba(76, 175, 80, 0.25);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.header-btn:active {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  transform: scale(0.98);
}

.list-item {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #C8E6C9;
}

.list-item__content {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.list-item__title {
  font-size: 32rpx;
  color: #1A1A1A;
  font-weight: 500;
}

.list-item__actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
}

.list-item__actions button {
  min-width: 80rpx;
  height: 56rpx;
  line-height: 56rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
  background-color: #C8E6C9;
  color: #666;
}

.list-item__actions button[bindtap="deleteDish"] {
  background-color: rgba(242, 92, 84, 0.1);
  color: #F25C54;
}

.dialog-content .input {
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 32rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 8rpx;
  background-color: #fff;
}
