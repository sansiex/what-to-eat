/* pages/dish-list/dish-list.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 头部操作区 */
.header-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
}

.btn-add-dish {
  width: 30%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  background: radial-gradient(ellipse at center, #fff 50%, #C8E6C9 100%);
  border: 2rpx dashed #81C784;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-danger {
  background: linear-gradient(135deg, #E53935 0%, #FF8A65 100%);
}

/* 菜品列表 */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜品卡片 */
.dish-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dish-image {
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.dish-count-bar {
  margin-bottom: 16rpx;
}

.dish-count-text {
  font-size: 24rpx;
  color: #999;
}

.dish-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A1A;
  line-height: 1.4;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 弹窗 ===== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  width: 92vw;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 删除图标：弹窗右上角 */
.dialog-delete-icon {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 48rpx;
  height: 48rpx;
  z-index: 10;
}

/* 标题 */
.dialog-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

/* 图片上传区 */
.upload-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.upload-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

.upload-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.upload-actions button {
  margin: 0;
  padding: 0 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 10rpx;
  text-align: center;
  box-sizing: border-box;
  box-shadow: none;
  min-width: 0;
  width: 100%;
}

.upload-actions button.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}

.upload-actions button.btn-danger {
  background: linear-gradient(135deg, #E53935 0%, #FF8A65 100%);
  color: #fff;
}

/* 表单输入 */
.form-input {
  width: 100%;
  min-height: 88rpx;
  line-height: 1.4;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
  margin-top: 16rpx;
}

/* 底部按钮 */
.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-btn {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn-cancel {
  background: #C8E6C9;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}
