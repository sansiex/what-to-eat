/* pages/dish-list/dish-list.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 头部操作区 */
.header-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: stretch;
}

.search-input {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
}

.btn-add-dish {
  width: 30%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  background: radial-gradient(ellipse at center, #fff 50%, #C8E6C9 100%);
  border: 2rpx dashed #81C784;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-danger {
  background: linear-gradient(135deg, #E53935 0%, #FF8A65 100%);
}

/* 菜品列表 */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜品卡片 */
.dish-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.dish-image {
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.dish-count-bar {
  margin-bottom: 16rpx;
}

.dish-count-text {
  font-size: 24rpx;
  color: #999;
}

.dish-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 弹窗 ===== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  width: 92vw;
  max-height: 80vh;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  overflow: hidden;
}

/* 中部随内容增高（不 flex-grow 避免短内容时留白）；总高度达 max-height 后仅此区域滚动 */
.dialog-scroll {
  flex: 0 1 auto;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  box-sizing: border-box;
}

/* 删除图标：弹窗右上角 */
.dialog-delete-icon {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 48rpx;
  height: 48rpx;
  z-index: 10;
}

/* 标题 */
.dialog-title {
  display: block;
  flex-shrink: 0;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

/* 图片上传区 */
.upload-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.upload-preview {
  width: 168rpx;
  height: 168rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

.upload-actions {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  flex: 1;
  min-width: 0;
}

.upload-actions button {
  margin: 0;
  padding: 0 12rpx;
  height: 52rpx;
  line-height: 52rpx;
  font-size: 26rpx;
  font-weight: 500;
  border-radius: 10rpx;
  text-align: center;
  box-sizing: border-box;
  box-shadow: none;
  min-width: 0;
  width: 100%;
}

.upload-actions button.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}

.upload-actions button.btn-danger {
  background: linear-gradient(135deg, #E53935 0%, #FF8A65 100%);
  color: #fff;
}

/* 编辑菜品：更换/移除图片按钮更窄、更高；与预览图间距更大 */
.upload-section--edit {
  gap: 40rpx;
}

.upload-section--edit .upload-actions {
  align-items: flex-start;
}

.upload-section--edit .upload-actions button {
  width: 62%;
  max-width: 240rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
}

/* 表单输入 */
.form-input {
  width: 100%;
  min-height: 88rpx;
  line-height: 1.4;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
  margin-top: 16rpx;
}

/* 描述：固定高度，长文在框内滚动（勿用 auto-height 撑满整屏） */
.form-input--textarea {
  display: block;
  min-height: 200rpx;
  height: 200rpx;
  max-height: 200rpx;
}

/* 底部按钮 */
.dialog-actions {
  display: flex;
  flex-shrink: 0;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-btn {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn-cancel {
  background: #C8E6C9;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}

/* 添加菜品：可选加入多个菜单（与上方表单同宽、左对齐） */
.add-to-menus-section {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #e8f5e9;
  width: 100%;
  align-self: stretch;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  text-align: left;
  box-sizing: border-box;
}

.add-to-menus-label {
  width: 100%;
  text-align: left;
  font-size: 26rpx;
  font-weight: 600;
  color: #555;
  margin-bottom: 12rpx;
  box-sizing: border-box;
  align-self: flex-start;
}

.add-to-menus-empty {
  padding: 16rpx 0;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
  text-align: left;
  width: 100%;
  box-sizing: border-box;
}

/* 菜单多选：输入框 + 下拉 */
.menu-select-wrap {
  position: relative;
  z-index: 5;
  width: 100%;
  align-self: stretch;
  box-sizing: border-box;
}

.menu-select-input {
  width: 100%;
  min-height: 88rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  border: 1rpx solid #c8e6c9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
  overflow: visible;
  align-self: stretch;
}

.menu-select-input--open {
  border-color: #66bb6a;
  box-shadow: 0 0 0 2rpx rgba(102, 187, 106, 0.2);
}

.menu-select-input-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  min-height: 52rpx;
  box-sizing: border-box;
}

.menu-select-chips {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  align-content: flex-start;
  gap: 10rpx;
}

.menu-select-placeholder {
  font-size: 28rpx;
  color: #bbb;
  line-height: 44rpx;
  text-align: left;
  width: 100%;
}

.menu-chip {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  max-width: 100%;
  padding: 6rpx 8rpx 6rpx 14rpx;
  background: #e8f5e9;
  border: 1rpx solid #a5d6a7;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.menu-chip-name {
  font-size: 24rpx;
  color: #2e7d32;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-chip-x {
  margin-left: 8rpx;
  padding: 0 8rpx;
  font-size: 28rpx;
  line-height: 1;
  color: #666;
  font-weight: 600;
}

.menu-select-caret {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #81c784;
  line-height: 1;
  transition: transform 0.2s ease;
}

.menu-select-input--open .menu-select-caret {
  transform: rotate(180deg);
}

/* 文档流展开，撑高弹窗；整体超出 80vh 时由 .dialog-scroll 滚动 */
.menu-select-dropdown {
  margin-top: 8rpx;
  width: 100%;
  background: #fff;
  border: 1rpx solid #c8e6c9;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 30;
  box-sizing: border-box;
}

.menu-dropdown-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 16rpx;
  border-bottom: 1rpx solid #f1f8f4;
}

.menu-dropdown-row:last-child {
  border-bottom: none;
}

.menu-dropdown-row:active {
  background: #f1f8f4;
}

.menu-checkbox-icon {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #81c784;
  border-radius: 8rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.menu-checkbox-icon--checked {
  background: linear-gradient(135deg, #66bb6a 0%, #81c784 100%);
  border-color: #66bb6a;
  position: relative;
}

.menu-checkbox-icon--checked::after {
  content: '';
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 10rpx;
  height: 18rpx;
  border: solid #fff;
  border-width: 0 4rpx 4rpx 0;
  transform: rotate(45deg);
}

.menu-checkbox-text {
  font-size: 28rpx;
  color: #333;
  flex: 1;
  min-width: 0;
}

/* 弹窗内下拉里菜单名更大、更易点 */
.menu-select-dropdown .menu-dropdown-row {
  padding: 24rpx 20rpx;
}

.menu-select-dropdown .menu-checkbox-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 20rpx;
}

.menu-select-dropdown .menu-checkbox-icon--checked::after {
  left: 10rpx;
  top: 5rpx;
  width: 12rpx;
  height: 20rpx;
}

.menu-select-dropdown .menu-checkbox-text {
  font-size: 36rpx;
  line-height: 1.35;
}
