/* pages/dish-list/dish-list.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 头部操作区 */
.header-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-danger {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

/* 菜品列表 */
.dish-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜品卡片 */
.dish-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.dish-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.dish-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.dish-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.dish-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card {
  display: flex;
  align-items: center;
}

/* ===== 弹窗 ===== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  width: 92vw;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* 删除图标：弹窗右上角 */
.dialog-delete-icon {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 48rpx;
  height: 48rpx;
  z-index: 10;
}

/* 标题 */
.dialog-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 24rpx;
}

/* 图片上传区 */
.upload-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.upload-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

.upload-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.upload-actions button {
  margin: 0;
  padding: 0 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 10rpx;
  text-align: center;
  box-sizing: border-box;
  box-shadow: none;
  min-width: 0;
  width: 100%;
}

.upload-actions button.btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.upload-actions button.btn-danger {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
}

/* 表单输入 */
.form-input {
  width: 100%;
  min-height: 88rpx;
  line-height: 1.4;
  padding: 18rpx 20rpx;
  font-size: 30rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fafafa;
  box-sizing: border-box;
  margin-top: 16rpx;
}

/* 底部按钮 */
.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-btn {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}
