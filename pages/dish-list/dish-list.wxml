<!-- pages/dish-list/dish-list.wxml -->
<view class="container">
  <kitchen-switcher id="kitchenSwitcher" bind:kitchenchange="onKitchenChange" />

  <!-- 搜索和添加 -->
  <view class="header-actions">
    <input 
      class="search-input" 
      placeholder="搜索菜品" 
      bindinput="onSearch"
      value="{{keyword}}"
    />
    <button class="btn btn-primary" bindtap="showAddDialog">添加菜品</button>
  </view>

  <!-- 菜品列表 -->
  <view class="dish-list">
    <view wx:if="{{dishes.length === 0}}" class="empty-state">
      <text>暂无菜品，点击上方按钮添加</text>
    </view>

    <view wx:else>
      <view wx:for="{{dishes}}" wx:key="id" class="dish-card" bindtap="showEditDialog" data-id="{{item.id}}">
        <image class="dish-image" src="{{item.displayImage}}" mode="aspectFill" catchtap="previewDishImage" data-url="{{item.displayImage}}" />
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.displayDescription}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 新增/编辑菜品弹窗 -->
  <view wx:if="{{showDishDialog}}" class="dialog-overlay">
    <view class="dialog">
      <image
        wx:if="{{dialogMode === 'edit'}}"
        class="dialog-delete-icon"
        src="/images/icon-delete.png"
        mode="aspectFit"
        catchtap="deleteDish"
      />
      <text class="dialog-title">{{dialogMode === 'edit' ? '编辑菜品' : '添加菜品'}}</text>

      <view class="upload-section">
        <image
          class="upload-preview"
          src="{{dishImageUrl || defaultDishImage}}"
          mode="aspectFill"
          catchtap="previewDishImage"
          data-url="{{dishImageUrl}}"
        />
        <view class="upload-actions">
          <button
            class="btn btn-small"
            bindtap="chooseDishImage"
            loading="{{isUploadingImage}}"
          >
            {{dishImageUrl ? '更换图片' : '上传图片'}}
          </button>
          <button
            wx:if="{{dishImageUrl}}"
            class="btn btn-small btn-danger"
            bindtap="removeDishImage"
          >
            移除图片
          </button>
        </view>
      </view>

      <input 
        class="form-input" 
        placeholder="请输入菜品名称" 
        bindinput="onDishNameInput"
        value="{{dishNameInput}}"
      />
      <textarea
        class="form-input" 
        placeholder="请输入菜品描述（可选，最多80字）" 
        bindinput="onDishDescInput"
        value="{{dishDescriptionInput}}"
        maxlength="80"
        auto-height
      />

      <view class="dialog-actions">
        <view class="dialog-btn dialog-btn-cancel" bindtap="hideDishDialog">取消</view>
        <view class="dialog-btn dialog-btn-confirm" bindtap="submitDish">确定</view>
      </view>
    </view>
  </view>
</view>
