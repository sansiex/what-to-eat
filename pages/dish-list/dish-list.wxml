<!-- pages/dish-list/dish-list.wxml -->
<page-meta page-style="{{showDishDialog ? 'overflow: hidden;' : ''}}" />
<view class="container">

  <!-- 菜品总数 -->
  <view wx:if="{{dishes.length > 0 && !listLoading}}" class="dish-count-bar">
    <text class="dish-count-text">共 {{dishes.length}} 道菜</text>
  </view>

  <!-- 搜索和添加 -->
  <view class="header-actions">
    <input 
      class="search-input" 
      placeholder="搜索菜品" 
      bindinput="onSearch"
      value="{{keyword}}"
    />
    <view class="btn-add-dish" bindtap="showAddDialog">添加菜品</view>
  </view>

  <!-- 菜品列表 -->
  <view class="dish-list">
    <view wx:if="{{listLoading}}" class="list-loading">
      <view class="list-loading-spinner" />
      <text class="list-loading-text">加载中...</text>
    </view>
    <view wx:elif="{{dishes.length === 0}}" class="empty-state">
      <text>暂无菜品，点击上方按钮添加</text>
    </view>

    <view wx:else>
      <view wx:for="{{dishes}}" wx:key="id" class="dish-card" bindtap="showEditDialog" data-id="{{item.id}}">
        <image class="dish-image" src="{{item.displayImage}}" mode="aspectFill" catchtap="previewDishImage" data-url="{{item.displayImage}}" />
        <view class="dish-info">
          <text class="dish-name">{{item.name}}</text>
          <text class="dish-desc">{{item.displayDescription}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 新增/编辑菜品弹窗 -->
  <view wx:if="{{showDishDialog}}" class="dialog-overlay">
    <view class="dialog">
      <image
        wx:if="{{dialogMode === 'edit'}}"
        class="dialog-delete-icon"
        src="/images/icon-delete.png"
        mode="aspectFit"
        catchtap="deleteDish"
      />
      <text class="dialog-title">{{dialogMode === 'edit' ? '编辑菜品' : '添加菜品'}}</text>

      <view class="dialog-scroll">
        <view class="upload-section {{dialogMode === 'edit' ? 'upload-section--edit' : ''}}">
          <image
            class="upload-preview"
            src="{{dishImageUrl || defaultDishImage}}"
            mode="aspectFill"
            catchtap="previewDishImage"
            data-url="{{dishImageUrl}}"
          />
          <view class="upload-actions">
            <button
              class="btn btn-small"
              bindtap="chooseDishImage"
              loading="{{isUploadingImage}}"
            >
              {{dishImageUrl ? '更换图片' : '上传图片'}}
            </button>
            <button
              wx:if="{{dishImageUrl}}"
              class="btn btn-small btn-danger"
              bindtap="removeDishImage"
            >
              移除图片
            </button>
          </view>
        </view>

        <input 
          class="form-input" 
          placeholder="请输入菜品名称" 
          bindinput="onDishNameInput"
          value="{{dishNameInput}}"
        />
        <textarea
          class="form-input form-input--textarea" 
          placeholder="请输入菜品描述（可选，最多80字）" 
          bindinput="onDishDescInput"
          value="{{dishDescriptionInput}}"
          maxlength="80"
        />

        <view wx:if="{{dialogMode === 'add'}}" class="add-to-menus-section">
        <view class="add-to-menus-label">同时加入菜单（可多选）</view>
        <view wx:if="{{addDialogMenus.length === 0}}" class="add-to-menus-empty">
          <text>暂无菜单，请先在「菜单」页创建；或确认已选择厨房</text>
        </view>
        <view wx:else class="menu-select-wrap">
          <view
            class="menu-select-input {{addDialogMenuPickerOpen ? 'menu-select-input--open' : ''}}"
            bindtap="toggleAddDialogMenuPicker"
          >
            <view class="menu-select-input-inner">
              <view class="menu-select-chips">
                <block wx:for="{{addDialogMenus}}" wx:key="id">
                  <view
                    wx:if="{{item.checked}}"
                    class="menu-chip"
                    catchtap="noopAddDialogMenu"
                  >
                    <text class="menu-chip-name">{{item.name}}</text>
                    <view
                      class="menu-chip-x"
                      catchtap="uncheckAddDialogMenu"
                      data-id="{{item.id}}"
                    >×</view>
                  </view>
                </block>
                <text wx:if="{{!addDialogHasChecked}}" class="menu-select-placeholder">请选择菜单</text>
              </view>
              <text class="menu-select-caret">▼</text>
            </view>
          </view>
          <view wx:if="{{addDialogMenuPickerOpen}}" class="menu-select-dropdown">
            <view
              wx:for="{{addDialogMenus}}"
              wx:key="id"
              class="menu-dropdown-row"
              catchtap="toggleAddDialogMenu"
              data-id="{{item.id}}"
            >
              <view class="menu-checkbox-icon {{item.checked ? 'menu-checkbox-icon--checked' : ''}}" />
              <text class="menu-checkbox-text">{{item.name}}</text>
            </view>
          </view>
        </view>
      </view>
      </view>

      <view class="dialog-actions">
        <view class="dialog-btn dialog-btn-cancel" bindtap="hideDishDialog">取消</view>
        <view class="dialog-btn dialog-btn-confirm" bindtap="submitDish">确定</view>
      </view>
    </view>
  </view>
</view>
