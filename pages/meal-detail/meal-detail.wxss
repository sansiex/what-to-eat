/* pages/meal-detail/meal-detail.wxss */
.container {
  padding: 24rpx;
  padding-bottom: 180rpx;
  min-height: 100vh;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.meal-scheduled-line {
  display: block;
  font-size: 26rpx;
  color: #000000;
  line-height: 1.35;
  margin-bottom: 12rpx;
}

.meal-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  flex: 1;
  min-width: 0;
}

.meal-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

.header-delete-icon {
  width: 52rpx;
  height: 52rpx;
  padding: 4rpx;
}

.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-ordering {
  background-color: #C8E6C9;
  color: #2E7D32;
}

.status-closed {
  background-color: #E0E0E0;
  color: #757575;
}

.meal-meta {
  margin-bottom: 32rpx;
}

.meta-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 20rpx;
}

.section-header-collapsible {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: -8rpx -8rpx 0;
  padding: 8rpx;
  border-radius: 12rpx;
}

.section-header-collapsible:active {
  opacity: 0.65;
}

.section-title--collapsible {
  flex: 1;
  margin-bottom: 0;
  min-width: 0;
}

.collapsible-hint {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.collapsible-arrow {
  font-size: 22rpx;
  color: #81C784;
  flex-shrink: 0;
  line-height: 1;
}

.section-header-collapsible + .dish-list {
  margin-top: 16rpx;
}

.dish-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.dish-block {
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 12rpx;
  margin-bottom: 8rpx;
}

.dish-block:last-child {
  border-bottom: none;
}

.dish-item {
  position: relative;
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

/* 角标占右下角，给文案右侧留白避免重叠 */
.dish-item--has-tag-badge {
  padding-right: 88rpx;
}

.dish-item--tap:active {
  opacity: 0.85;
}

.dish-img-wrap {
  width: 136rpx;
  height: 136rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
}

.dish-img {
  display: block;
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
  background: #f2f4f7;
}

/* 有人打过标签：整行列表项右下角角标（相对 .dish-item） */
.dish-tag-corner-badge {
  position: absolute;
  right: 0;
  bottom: 8rpx;
  padding: 4rpx 10rpx;
  background: rgba(21, 101, 192, 0.92);
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1.2;
  letter-spacing: 0.02em;
  border-radius: 8rpx;
  pointer-events: none;
  z-index: 1;
}

.dish-info {
  margin-left: 28rpx;
  flex: 1;
  min-width: 0;
}

.dish-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
  margin-bottom: 4rpx;
}

.dish-desc {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 4rpx;
  line-height: 1.45;
}

.dish-orderers {
  font-size: 24rpx;
  color: #999;
}

.dish-desc--collapsed {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.dish-desc--expanded {
  white-space: normal;
  overflow: visible;
  word-break: break-word;
}

.dish-tag-panel {
  padding: 12rpx 0 8rpx 164rpx;
}

.meal-detail-tag-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.meal-detail-tag-users {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.meal-detail-tag-empty {
  font-size: 24rpx;
  color: #999;
}

.dish-tag-pill {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
}

.dish-tag-pill--red {
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
}

.dish-tag-pill--blue {
  background: linear-gradient(135deg, #1565c0 0%, #1e88e5 100%);
}

.empty-state {
  padding: 80rpx 0;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

/* 底部操作按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 12rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  border: none;
  color: #fff;
}

.btn-icon {
  width: 40rpx;
  height: 40rpx;
}

.btn-edit {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
}

.btn-order {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.btn-close {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.btn-share {
  background: linear-gradient(135deg, #E53935 0%, #ee5a6f 100%);
}

.action-btn::after {
  border: none;
}
