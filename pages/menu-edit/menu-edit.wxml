<!-- pages/menu-edit/menu-edit.wxml -->
<view class="container">
  <view class="page-header">
    <text class="page-title">{{isEditMode ? '编辑菜单' : '创建菜单'}}</text>
    <image
      wx:if="{{isEditMode}}"
      class="header-delete-icon"
      src="/images/icon-delete.png"
      mode="aspectFit"
      bindtap="deleteMenu"
    />
  </view>

  <!-- 菜单名称 -->
  <view class="form-section">
    <text class="form-label">菜单名称</text>
    <!-- 快捷输入标签 -->
    <view class="quick-tags">
      <view class="quick-tag" bindtap="onQuickTagTap" data-tag="早餐">早餐</view>
      <view class="quick-tag" bindtap="onQuickTagTap" data-tag="午餐">午餐</view>
      <view class="quick-tag" bindtap="onQuickTagTap" data-tag="晚餐">晚餐</view>
      <view class="quick-tag" bindtap="onQuickTagTap" data-tag="下午茶">下午茶</view>
      <view class="quick-tag" bindtap="onQuickTagTap" data-tag="夜宵">夜宵</view>
    </view>
    <input 
      class="form-input" 
      placeholder="请输入菜单名称（如：午餐、晚餐）" 
      bindinput="onMenuNameInput"
      value="{{menuName}}"
    />
  </view>

  <!-- 菜品选择 -->
  <view class="form-section">
    <text class="form-label">选择菜品</text>
    
    <!-- 搜索和新增 -->
    <view class="header-actions">
      <input 
        class="search-input" 
        placeholder="搜索菜品" 
        bindinput="onSearch"
        value="{{searchKeyword}}"
      />
      <view class="btn-add-dish" bindtap="showAddDishDialog">新增菜品</view>
    </view>

    <!-- Tab：在菜单中 / 不在菜单中 -->
    <view class="dish-tabs">
      <view
        class="dish-tab {{dishTab === 'in' ? 'dish-tab--active' : ''}}"
        bindtap="switchDishTab"
        data-tab="in"
      >
        <text class="dish-tab__label">在菜单中</text>
        <text class="dish-tab__count">（{{dishesInMenu.length}}）</text>
      </view>
      <view
        class="dish-tab {{dishTab === 'out' ? 'dish-tab--active' : ''}}"
        bindtap="switchDishTab"
        data-tab="out"
      >
        <text class="dish-tab__label">不在菜单中</text>
        <text class="dish-tab__count">（{{dishesNotInMenu.length}}）</text>
      </view>
    </view>

    <!-- 在菜单中 -->
    <view wx:if="{{dishTab === 'in'}}" class="dishes-tab-panel">
      <view wx:if="{{dishesInMenu.length > 0}}" class="tab-panel-toolbar">
        <view class="section-action" bindtap="toggleSelectAllInMenu">{{inMenuAllSelected ? '全不选' : '全选'}}</view>
      </view>
      <view wx:if="{{dishesInMenu.length === 0}}" class="empty-tip-small">
        <text>暂无，可切换到「不在菜单中」勾选添加</text>
      </view>
      <view wx:else class="dishes-list dishes-list--tab">
        <view
          wx:for="{{dishesInMenu}}"
          wx:key="id"
          class="dish-item {{item.selected ? 'selected' : ''}}"
          bindtap="toggleDishSelection"
          data-id="{{item.id}}"
        >
          <checkbox checked="{{item.selected}}" />
          <image class="dish-thumb" src="{{item.displayImage}}" mode="aspectFill" catchtap="previewDishImage" data-url="{{item.displayImage}}" />
          <view class="dish-text">
            <text class="dish-name">{{item.name}}</text>
            <text class="dish-desc">{{item.displayDescription}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 不在菜单中 -->
    <view wx:if="{{dishTab === 'out'}}" class="dishes-tab-panel">
      <view wx:if="{{dishesNotInMenu.length > 0}}" class="tab-panel-toolbar">
        <view class="section-action" bindtap="toggleSelectAllNotInMenu">{{notInMenuAllSelected ? '全不选' : '全选'}}</view>
      </view>
      <view wx:if="{{dishesNotInMenu.length === 0}}" class="empty-tip-small">
        <text>全部已加入菜单</text>
      </view>
      <view wx:else class="dishes-list dishes-list--tab">
        <view
          wx:for="{{dishesNotInMenu}}"
          wx:key="id"
          class="dish-item {{item.selected ? 'selected' : ''}}"
          bindtap="toggleDishSelection"
          data-id="{{item.id}}"
        >
          <checkbox checked="{{item.selected}}" />
          <image class="dish-thumb" src="{{item.displayImage}}" mode="aspectFill" catchtap="previewDishImage" data-url="{{item.displayImage}}" />
          <view class="dish-text">
            <text class="dish-name">{{item.name}}</text>
            <text class="dish-desc">{{item.displayDescription}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="form-actions">
    <button class="btn btn-primary" bindtap="saveMenu">
      {{isEditMode ? '保存修改' : '创建菜单'}}
    </button>
    <button wx:if="{{isEditMode}}" class="btn btn-primary btn-save-and-initiate" bindtap="saveAndInitiate">
      保存并发起点餐
    </button>
  </view>

  <!-- 新增菜品弹窗 -->
  <view wx:if="{{showAddDishDialog}}" class="dialog-overlay">
    <view class="dialog">
      <text class="dialog-title">新增菜品</text>

      <view class="upload-section">
        <image class="upload-preview" src="{{newDishImageUrl || defaultDishImage}}" mode="aspectFill" catchtap="previewDishImage" data-url="{{newDishImageUrl}}" />
        <view class="upload-actions">
          <button class="btn btn-small" bindtap="chooseNewDishImage" loading="{{isUploadingImage}}">
            {{newDishImageUrl ? '更换图片' : '上传图片'}}
          </button>
          <button wx:if="{{newDishImageUrl}}" class="btn btn-small btn-danger" bindtap="removeNewDishImage">移除图片</button>
        </view>
      </view>

      <input 
        class="form-input" 
        placeholder="请输入菜品名称" 
        bindinput="onNewDishNameInput"
        value="{{newDishName}}"
        focus="{{showAddDishDialog}}"
      />
      <textarea
        class="form-input"
        placeholder="请输入菜品描述（可选，最多80字）"
        bindinput="onNewDishDescriptionInput"
        value="{{newDishDescription}}"
        maxlength="80"
        auto-height
      />

      <view class="dialog-actions">
        <view class="dialog-btn dialog-btn-cancel" bindtap="hideAddDishDialog">取消</view>
        <view class="dialog-btn dialog-btn-confirm" bindtap="confirmAddDish">确定</view>
      </view>
    </view>
  </view>
</view>
