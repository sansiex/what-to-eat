/* pages/menu-edit/menu-edit.wxss */

.container.page-menu-edit {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 20rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
}

.form-section--menu-meta {
  flex-shrink: 0;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  flex-shrink: 0;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.header-delete-icon {
  width: 52rpx;
  height: 52rpx;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 选择菜品：占满除菜单名称与底栏外的剩余高度 */
.form-section--dishes {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  margin-bottom: 0;
}

.menu-edit-dish-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
}

.menu-edit-dish-empty-fill {
  flex: 1;
  min-height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* scroll-view 在 flex 子项内需 height:0+flex:1 才能撑满剩余区域 */
.dishes-list-scroll-inner {
  flex: 1;
  min-height: 0;
  height: 0;
  width: 100%;
  box-sizing: border-box;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  line-height: 1.4;
  padding: 18rpx 24rpx;
  font-size: 30rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
}

/* 搜索和新增 - 与菜品列表页一致 */
.header-actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
  align-items: stretch;
}

.btn-add-dish {
  width: 30%;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  background: radial-gradient(ellipse at center, #fff 50%, #C8E6C9 100%);
  border: 2rpx dashed #81C784;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 快捷输入标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-tag {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.25);
}

.quick-tag:active {
  opacity: 0.8;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-cancel {
  background: #C8E6C9;
  color: #666;
  flex: 1;
  margin-right: 16rpx;
}

.btn-confirm {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  flex: 1;
  margin-left: 16rpx;
}

/* 搜索框 */
.search-input {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
  box-sizing: border-box;
}

/* 说明与全选同一行 */
.menu-edit-hint-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.menu-edit-dish-hint {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: #666;
  line-height: 1.45;
}

.menu-edit-hint-row__action {
  flex-shrink: 0;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.section-action {
  font-size: 26rpx;
  color: #007AFF;
}

.empty-tip-small {
  padding: 24rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

/* 旧：固定高度列表（已改为 scroll-view 撑满） */
.dishes-list {
  max-height: 400rpx;
  overflow-y: auto;
}

.dishes-list--tab {
  max-height: 560rpx;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #C8E6C9;
  gap: 28rpx;
}

.dish-item.selected {
  background-color: #C8E6C9;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-name {
  font-size: 40rpx;
  color: #1a1a1a;
  margin-left: 0;
  font-weight: 600;
}

.dish-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dish-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-thumb {
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

/* 勾选框在列表项右侧 */
.dish-item .dish-item-check {
  flex-shrink: 0;
  margin-left: 16rpx;
  margin-right: 0;
}

/* 表单操作 - 固定在屏幕底部 */
.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #fff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-actions .btn {
  flex: 1;
}

.menu-edit-submit-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
}

.menu-edit-submit-icon {
  flex-shrink: 0;
  vertical-align: middle;
}

.btn-save-and-initiate {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

/* ===== 弹窗 ===== */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  width: 92vw;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.dialog-title {
  display: block;
  text-align: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 24rpx;
}

.upload-section {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.upload-preview {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

.upload-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.upload-actions button {
  margin: 0;
  padding: 0 16rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 500;
  border-radius: 10rpx;
  text-align: center;
  box-sizing: border-box;
  box-shadow: none;
  min-width: 0;
  width: 100%;
}

.upload-actions button.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}

.upload-actions button.btn-danger {
  background: linear-gradient(135deg, #E53935 0%, #FF8A65 100%);
  color: #fff;
}

.dialog .form-input {
  margin-top: 16rpx;
}

.dialog-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.dialog-btn {
  flex: 1;
  height: 76rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dialog-btn-cancel {
  background: #C8E6C9;
  color: #666;
}

.dialog-btn-confirm {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}
