/* pages/menu-edit/menu-edit.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 页面标题 */
.page-header {
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

/* 表单区域 */
.form-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.form-input {
  width: 100%;
  min-height: 88rpx;
  line-height: 1.4;
  padding: 18rpx 24rpx;
  font-size: 30rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fafafa;
  box-sizing: border-box;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* 快捷输入标签 */
.quick-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.quick-tag {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.3);
}

.quick-tag:active {
  opacity: 0.8;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
  flex: 1;
  margin-right: 16rpx;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  flex: 1;
  margin-left: 16rpx;
}

/* 搜索框 */
.search-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fafafa;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

/* 菜品列表 */
.dishes-list {
  max-height: 600rpx;
  overflow-y: auto;
}

.empty-tip {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  gap: 14rpx;
}

.dish-item.selected {
  background-color: rgba(102, 126, 234, 0.05);
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-name {
  font-size: 28rpx;
  color: #333;
  margin-left: 0;
  font-weight: 600;
}

.dish-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dish-desc {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-thumb {
  width: 84rpx;
  height: 84rpx;
  border-radius: 10rpx;
  background: #f2f4f7;
  flex-shrink: 0;
}

/* 表单操作 */
.form-actions {
  margin-top: 40rpx;
}

/* 弹窗样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.dialog {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  display: flex;
  flex-direction: column;
}

.dialog-header {
  position: relative;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  text-align: center;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.dialog-close {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx 20rpx;
}

.dialog-content {
  padding: 30rpx;
}

.dish-upload {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.dish-upload__preview {
  width: 100%;
  aspect-ratio: 1 / 1;
  border-radius: 10rpx;
  background: #f2f4f7;
}

.dish-upload__actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
}

.dish-upload__actions .btn {
  flex: 1;
  padding: 14rpx 0;
  font-size: 24rpx;
  margin: 0;
}

.dialog-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #eee;
  box-sizing: border-box;
  gap: 20rpx;
}

.dialog-actions .btn {
  width: 200rpx;
  margin: 0;
  padding: 24rpx 0;
  font-size: 30rpx;
  border: none;
  border-radius: 12rpx;
  text-align: center;
  box-sizing: border-box;
}

.dialog-actions .btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.dialog-actions .btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}
