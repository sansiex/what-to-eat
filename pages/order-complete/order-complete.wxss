/* pages/order-complete/order-complete.wxss */

.container {
  padding: 20rpx 20rpx 180rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 成功横幅 */
.success-banner {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 36rpx;
}

.success-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #1A1A1A;
}

.success-sub {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #999;
}

/* 区块 */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 16rpx;
}

.section-title--muted {
  color: #999;
}

/* 菜品行 */
.dish-row {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #C8E6C9;
  gap: 28rpx;
}

.dish-row:last-child {
  border-bottom: none;
}

.dish-row--muted {
  opacity: 0.45;
}

.dish-thumb {
  width: 136rpx;
  height: 136rpx;
  border-radius: 12rpx;
  background: #C8E6C9;
  flex-shrink: 0;
}

.dish-text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.dish-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.dish-name--muted {
  color: #999;
}

.dish-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
  line-height: 1.45;
}

.dish-desc--collapsed {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.dish-desc--expanded {
  white-space: normal;
  overflow: visible;
  word-break: break-word;
}

.oc-dish-block {
  border-bottom: 1rpx solid #e8f5e9;
  margin-bottom: 8rpx;
  padding-bottom: 8rpx;
}

.oc-dish-block:last-child {
  border-bottom: none;
}

/* 与点餐页折叠态一致：无「我的标签」标题、无 X；左缘与缩略图左缘对齐（本页无勾选框） */
.oc-my-tags-collapsed {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #e8f5e9;
  width: 100%;
  box-sizing: border-box;
}

.oc-my-tags-collapsed-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
}

.dish-tag-pill--oc-collapsed {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
  color: #fff;
}

.oc-my-tags-expanded {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.oc-tag-panel {
  padding: 12rpx 0 8rpx 164rpx;
}

.oc-tag-line {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.oc-tag-users {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  line-height: 1.5;
}

.oc-tag-empty {
  font-size: 24rpx;
  color: #999;
}

.dish-tag-pill {
  display: inline-flex;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
}

.dish-tag-pill--red {
  background: linear-gradient(135deg, #e53935 0%, #ef5350 100%);
}

.dish-tag-pill--blue {
  background: linear-gradient(135deg, #1565c0 0%, #1e88e5 100%);
}

.dish-badge {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 700;
  flex-shrink: 0;
}

/* 操作按钮栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.04);
}

.btn {
  flex: 1;
  min-height: 88rpx;
  height: auto;
  line-height: 1.25;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 16rpx 12rpx;
  margin: 0;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.btn::after {
  border: none;
}

.btn-with-icon__img {
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  margin-bottom: 6rpx;
}

.btn-with-icon__text {
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1.2;
}

.btn-primary {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}

.btn-secondary {
  background: #C8E6C9;
  color: #666;
}
