<!-- pages/menu-list/menu-list.wxml -->
<view class="container">
  <kitchen-switcher id="kitchenSwitcher" bind:kitchenchange="onKitchenChange" />

  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-card create-menu-card" bindtap="createMenu">
      <text class="create-menu-text">创建新菜单</text>
    </view>

    <view wx:for="{{menus}}" wx:key="id" class="menu-card" bindtap="editMenu" data-id="{{item.id}}">
      <view class="menu-info">
        <text class="menu-name">{{item.name}}</text>
        <text class="menu-count">{{item.dishCount}} 道菜</text>
      </view>
      <image
        class="menu-action-icon"
        src="/images/icon-start-meal.png"
        mode="aspectFit"
        catchtap="showInitiateMealDialog"
        data-id="{{item.id}}"
      />
    </view>
  </view>

  <!-- 发起点餐弹窗 -->
  <view wx:if="{{showInitiateDialog}}" class="dialog-overlay">
    <view class="dialog">
      <view class="dialog-header">
        <text class="dialog-title">确认发起点餐</text>
        <text class="dialog-close" bindtap="hideInitiateDialog">×</text>
      </view>
      
      <view class="dialog-content">
        <!-- 菜单名称 -->
        <view class="menu-name-section">
          <text class="label">菜单名称：</text>
          <text class="value">{{selectedMenu.name}}</text>
        </view>

        <!-- 搜索框 -->
        <view class="search-section">
          <input 
            class="search-input" 
            placeholder="搜索菜品" 
            bindinput="onSearchDishes"
            value="{{searchKeyword}}"
          />
        </view>

        <!-- 菜品列表 -->
        <view class="dishes-section">
          <text class="section-title">菜品列表（{{selectedCount}}/{{selectedMenu.dishes.length}}）</text>
          <scroll-view class="dishes-scroll" scroll-y>
            <view wx:for="{{filteredDishes}}" wx:key="id" class="dish-item" bindtap="toggleDishSelection" data-id="{{item.id}}">
              <view class="checkbox {{item.selected ? 'checked' : ''}}">
                <view wx:if="{{item.selected}}" class="checkmark">✓</view>
              </view>
              <image
                src="{{item.imageUrl || '/images/dish-placeholder.png'}}"
                mode="aspectFill"
                style="width: 72rpx; height: 72rpx; border-radius: 8rpx; margin-right: 12rpx; background: #f2f4f7;"
                catchtap="previewDishImage"
                data-url="{{item.imageUrl}}"
              />
              <view style="flex: 1; display: flex; flex-direction: column; min-width: 0;">
                <text class="dish-name {{item.selected ? '' : 'disabled'}}">{{item.name}}</text>
                <text style="font-size: 20rpx; color: #999; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {{item.description || '暂无描述'}}
                </text>
              </view>
            </view>
          </scroll-view>
        </view>
      </view>

      <view class="dialog-actions">
        <button class="btn btn-cancel" bindtap="hideInitiateDialog">取消</button>
        <button class="btn btn-confirm" bindtap="confirmInitiateMeal">确定</button>
      </view>
    </view>
  </view>
</view>
