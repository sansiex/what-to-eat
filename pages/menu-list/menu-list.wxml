<!-- pages/menu-list/menu-list.wxml -->
<view class="container">
  <!-- 菜单列表 -->
  <view class="menu-list">
    <view class="menu-top-row">
      <view class="menu-top-card create-menu-card" bindtap="createMenu">
        <text class="create-menu-text">创建新菜单</text>
      </view>
      <view class="menu-top-card dish-entry-card" bindtap="goDishList">
        <text class="dish-entry-text">菜品</text>
      </view>
    </view>

    <view wx:for="{{menus}}" wx:key="id" class="menu-card" bindtap="editMenu" data-id="{{item.id}}">
      <view class="menu-info">
        <text class="menu-name">{{item.name}}</text>
        <text class="menu-count">{{item.dishCount}} 道菜</text>
      </view>
      <view class="menu-start-meal-btn" catchtap="goInitiateMeal" data-id="{{item.id}}">
        <image class="menu-start-meal-btn__icon" src="/images/icon-start-meal.png" mode="aspectFit" />
        <text class="menu-start-meal-btn__text">发起点餐</text>
      </view>
    </view>
  </view>
</view>
