/* pages/menu-list/menu-list.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 创建新菜单卡片 */
.create-menu-card {
  background: radial-gradient(ellipse at center, #fff 50%, #C8E6C9 100%) !important;
  justify-content: center !important;
  border: 2rpx dashed #81C784;
}

.create-menu-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.menu-card {
  display: flex;
  align-items: center;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.menu-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.menu-action-icon {
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}
