/* pages/menu-list/menu-list.wxss */

.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 头部操作区 */
.header-actions {
  margin-bottom: 20rpx;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  flex: 1;
  margin: 0 8rpx;
}

.btn-tiny {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
}

.btn-danger {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.menu-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.menu-count {
  font-size: 24rpx;
  color: #999;
}

.menu-actions {
  display: flex;
  gap: 12rpx;
}

/* 弹窗样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  margin: 0 auto;
}

.dialog-header {
  position: relative;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  text-align: center;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.dialog-close {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx 20rpx;
}

.dialog-content {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.dialog-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.dialog-actions .btn {
  width: 200rpx;
  margin: 0;
  padding: 24rpx 0;
  font-size: 30rpx;
  border: none;
  border-radius: 12rpx;
  text-align: center;
}

/* 弹窗内容样式 */
.menu-name-section {
  margin-bottom: 24rpx;
}

.menu-name-section .label {
  font-size: 28rpx;
  color: #666;
}

.menu-name-section .value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-left: 12rpx;
}

.search-section {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  background-color: #fafafa;
}

.dishes-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 400rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.dishes-scroll {
  flex: 1;
  max-height: 500rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.checkbox.checked {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-color: transparent;
}

.checkmark {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.dish-name {
  font-size: 30rpx;
  color: #333;
  flex: 1;
}

.dish-name.disabled {
  color: #999;
  text-decoration: line-through;
}
