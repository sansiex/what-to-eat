/* pages/menu-list/menu-list.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 创建新菜单卡片 */
.create-menu-card {
  background: radial-gradient(ellipse at center, #fff 50%, #C8E6C9 100%) !important;
  justify-content: center !important;
  border: 2rpx dashed #81C784;
}

.create-menu-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.menu-card {
  display: flex;
  align-items: center;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-name {
  font-size: 38rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.menu-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 发起点餐：横向长方形 + 圆角 + 图标文案 */
.menu-start-meal-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 20rpx;
  padding: 20rpx 32rpx;
  min-height: 80rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #66bb6a 0%, #81c784 100%);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.28);
}

.menu-start-meal-btn:active {
  opacity: 0.92;
}

.menu-start-meal-btn__icon {
  width: 40rpx;
  height: 40rpx;
  flex-shrink: 0;
  margin-right: 12rpx;
}

.menu-start-meal-btn__text {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.2;
}
