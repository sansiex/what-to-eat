/* pages/menu-list/menu-list.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 创建新菜单卡片 */
.create-menu-card {
  background: radial-gradient(ellipse at center, #fff 50%, #C8E6C9 100%) !important;
  justify-content: center !important;
  border: 2rpx dashed #81C784;
}

.create-menu-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #666;
}

/* 按钮样式 */
.btn {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  flex: 1;
  margin: 0 8rpx;
}

.btn-tiny {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
}

.btn-danger {
  background: linear-gradient(135deg, #E53935 0%, #FF8A65 100%);
}

.btn-cancel {
  background: #C8E6C9;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
}

/* 菜单列表 */
.menu-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999;
  font-size: 28rpx;
}

/* 菜单卡片 */
.menu-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.menu-card {
  display: flex;
  align-items: center;
}

.menu-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.menu-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.menu-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.menu-action-icon {
  width: 100rpx;
  height: 100rpx;
  flex-shrink: 0;
  margin-left: 20rpx;
}

/* 弹窗样式 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog {
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  margin: 0 auto;
}

.dialog-header {
  position: relative;
  padding: 30rpx;
  border-bottom: 1rpx solid #C8E6C9;
  text-align: center;
}

.dialog-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A1A;
}

.dialog-close {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx 20rpx;
}

.dialog-content {
  padding: 30rpx;
  flex: 1;
  overflow-y: auto;
}

.dialog-actions {
  display: flex;
  flex-direction: row;
  justify-content: center;
  padding: 20rpx 30rpx 30rpx;
  border-top: 1rpx solid #C8E6C9;
  gap: 20rpx;
}

.dialog-actions .btn {
  width: 200rpx;
  margin: 0;
  padding: 24rpx 0;
  font-size: 30rpx;
  border: none;
  border-radius: 12rpx;
  text-align: center;
}

/* 弹窗内容样式 */
.menu-name-section {
  margin-bottom: 24rpx;
}

.menu-name-section .label {
  font-size: 28rpx;
  color: #666;
}

.menu-name-section .value {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A1A;
  margin-left: 12rpx;
}

.search-section {
  margin-bottom: 24rpx;
}

.search-input {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  background-color: #fff;
}

.dishes-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 400rpx;
}

.section-title {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  display: block;
}

.dishes-scroll {
  flex: 1;
  max-height: 500rpx;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #C8E6C9;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #C8E6C9;
  border-radius: 8rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.checkbox.checked {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  border-color: transparent;
}

.checkmark {
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.dish-name {
  font-size: 30rpx;
  color: #1A1A1A;
  flex: 1;
}

.dish-name.disabled {
  color: #999;
  text-decoration: line-through;
}
