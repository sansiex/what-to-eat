<!-- pages/kitchen-manage/kitchen-manage.wxml -->
<view class="container">
  <!-- 厨房名称 -->
  <view class="section">
    <text class="section-title">厨房名称</text>
    <view class="name-row">
      <input
        class="name-input"
        value="{{kitchenName}}"
        bindinput="onNameInput"
        placeholder="输入厨房名称"
      />
      <button
        wx:if="{{kitchenName !== originalName}}"
        class="btn-save"
        bindtap="saveName"
      >保存</button>
    </view>
  </view>

  <!-- 管理员列表 -->
  <view class="section">
    <text class="section-title">管理员（{{members.length}}人）</text>

    <view wx:if="{{members.length === 0}}" class="empty-state">
      <text>暂无管理员，点击下方按钮邀请</text>
    </view>

    <view wx:else class="member-list">
      <view wx:for="{{members}}" wx:key="id" class="member-item">
        <view class="member-avatar">
          <image
            wx:if="{{item.avatarUrl}}"
            src="{{item.avatarUrl}}"
            mode="aspectFill"
            class="avatar-img"
          />
          <text wx:else class="avatar-placeholder">👤</text>
        </view>
        <view class="member-info">
          <text class="member-name">{{item.nickname || '未知用户'}}</text>
          <text class="member-time">加入时间：{{item.joinedAt}}</text>
        </view>
        <button class="btn-remove" bindtap="removeMember" data-id="{{item.id}}" data-name="{{item.nickname}}">
          移除
        </button>
      </view>
    </view>
  </view>

  <!-- 邀请按钮 -->
  <button class="btn-invite" open-type="share">+ 邀请管理员</button>
</view>
