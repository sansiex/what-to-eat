/* pages/kitchen-manage/kitchen-manage.wxss */

.container {
  padding: 20rpx;
  min-height: 100vh;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A1A;
  display: block;
  margin-bottom: 16rpx;
}

.switch-kitchen-link {
  font-size: 24rpx;
  color: #2E7D32;
  background: #E8F5E9;
  padding: 10rpx 20rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  line-height: 1.3;
}

.name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.name-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #C8E6C9;
  border-radius: 10rpx;
  font-size: 28rpx;
  background: #fff;
}

.name-input--readonly {
  background: #f5f5f5;
  color: #666;
}

.kitchen-name-title-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* 副标题单独一行（角色在标题行） */
.kitchen-meta-row {
  margin-top: 16rpx;
  padding-top: 8rpx;
}

.kitchen-meta-subtitle {
  display: block;
  font-size: 22rpx;
  color: #999;
  line-height: 1.4;
}

.kitchen-meta-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.kitchen-meta-badge--owner {
  background: #fff3e0;
  color: #e65100;
}

.kitchen-meta-badge--admin {
  background: #c8e6c9;
  color: #2e7d32;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.section-title--inline {
  margin-bottom: 0;
  flex: 1;
  min-width: 0;
}

.btn-invite-inline {
  padding: 0 20rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  border-radius: 10rpx;
  border: none;
  flex-shrink: 0;
}

.btn-invite-inline::after {
  border: none;
}

.btn-save {
  padding: 0 28rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 26rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  border-radius: 10rpx;
  border: none;
  flex-shrink: 0;
}

.empty-state {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-state--admin-intro {
  text-align: left;
  line-height: 1.65;
  color: #666;
  padding: 32rpx 8rpx 40rpx;
  font-size: 26rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #C8E6C9;
  gap: 16rpx;
}

.member-item:last-child {
  border-bottom: none;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #C8E6C9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  font-size: 36rpx;
}

.member-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A1A1A;
}

.member-time {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.btn-remove {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #E53935;
  background: rgba(229, 57, 53, 0.08);
  border: 1rpx solid rgba(229, 57, 53, 0.2);
  border-radius: 8rpx;
  flex-shrink: 0;
  line-height: 1.5;
}

.btn-remove::after {
  border: none;
}

