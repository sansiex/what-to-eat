<!-- pages/order-food/order-food.wxml -->
<view class="container order-food-page">
  <!-- 餐名显示 -->
  <view class="section" wx:if="{{currentMeal}}">
    <text style="font-size: 36rpx; font-weight: 600; display: block; margin-bottom: 12rpx;">
      {{currentMeal.name}}
    </text>
    <text style="font-size: 24rpx; color: #999;">
      发起时间：{{currentMeal.formattedCreatedAt}}
    </text>
    <!-- 已收单标记 -->
    <text wx:if="{{viewMode}}" style="font-size: 24rpx; color: #999; margin-top: 8rpx; display: block;">
      已收单
    </text>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar" wx:if="{{!viewMode}}">
    <text class="search-icon">🔍</text>
    <input
      class="search-input"
      placeholder="搜索菜品"
      bindinput="onSearch"
      value="{{searchKeyword}}"
    />
  </view>

  <!-- 菜品列表 -->
  <view class="section">
    <view wx:if="{{!currentMeal}}" style="padding: 40rpx 0; text-align: center; color: #999;">
      暂无发起的餐食，请先发起一餐
    </view>

    <view wx:elif="{{filteredDishes.length === 0}}" style="padding: 40rpx 0; text-align: center; color: #999;">
      没有找到匹配的菜品
    </view>

    <view wx:else>
      <!-- 正常模式：带复选框 -->
      <checkbox-group wx:if="{{!viewMode}}" bindchange="onCheckboxChange">
        <view wx:for="{{filteredDishes}}" wx:key="id" class="list-item order-food-dish-item">
          <view class="order-food-dish-row">
            <!-- 复选框 -->
            <checkbox
              value="{{item.id}}"
              checked="{{dishSelectionMap[item.id] || false}}"
              class="order-food-dish-check"
            />

            <image
              class="dish-list-thumb"
              src="{{item.displayImage || '/images/dish-placeholder.png'}}"
              mode="aspectFill"
              catchtap="previewDishImage"
              data-url="{{item.displayImage || '/images/dish-placeholder.png'}}"
            />
            <view class="order-food-dish-text">
              <text class="list-item__title" style="margin-bottom: 4rpx;">{{item.name}}</text>
              <text class="list-item__desc" style="margin-bottom: 8rpx;">{{item.displayDescription || item.description || '暂无描述'}}</text>
              <text class="list-item__desc">{{dishOrderersMap[item.id] || '暂无点选'}}</text>
            </view>
          </view>
        </view>
      </checkbox-group>

      <!-- 查看模式：只显示列表 -->
      <view wx:else>
        <view wx:for="{{filteredDishes}}" wx:key="id" class="list-item order-food-dish-item">
          <view class="order-food-dish-row">
            <image
              class="dish-list-thumb"
              src="{{item.displayImage || '/images/dish-placeholder.png'}}"
              mode="aspectFill"
              bindtap="previewDishImage"
              data-url="{{item.displayImage || '/images/dish-placeholder.png'}}"
            />
            <view class="order-food-dish-text">
              <text class="list-item__title" style="margin-bottom: 4rpx;">{{item.name}}</text>
              <text class="list-item__desc" style="margin-bottom: 8rpx;">{{item.displayDescription || item.description || '暂无描述'}}</text>
              <text class="list-item__desc">{{dishOrderersMap[item.id] || '暂无点选'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 按钮区域（仅正常模式显示） -->
  <view wx:if="{{currentMeal && !viewMode}}" style="display: flex; gap: 16rpx; width: 100%;">
    <button
      class="btn"
      bindtap="placeOrder"
      style="flex: 1;"
    >
      下单
    </button>
    <button
      class="btn btn-share"
      style="flex: 1;"
      wx:if="{{isInitiator}}"
      open-type="share"
      data-id="{{currentMeal.id}}"
      data-name="{{currentMeal.name}}"
    >
      分享
    </button>
  </view>
</view>
