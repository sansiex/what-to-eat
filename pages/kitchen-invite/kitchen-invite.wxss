/* pages/kitchen-invite/kitchen-invite.wxss */

.container {
  padding: 40rpx 24rpx;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.center-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #388E3C;
}

.icon-large {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: 30rpx;
  color: #388E3C;
  margin-bottom: 40rpx;
}

.invite-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-top: 60rpx;
}

.invite-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.invite-title {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.invite-kitchen {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A1A;
  margin-bottom: 32rpx;
}

.invite-meta {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 48rpx;
}

.meta-item {
  font-size: 26rpx;
  color: #388E3C;
}

.already-member {
  font-size: 28rpx;
  color: #4CAF50;
  margin-bottom: 24rpx;
}

.btn-primary {
  width: 80%;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  border-radius: 12rpx;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.25);
}

.btn-primary::after {
  border: none;
}
