/* pages/meal-list/meal-list.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
}

/* 点餐列表 */
.meal-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.meal-item {
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  cursor: pointer;
  border-left: 6rpx solid transparent;
}

/* 点餐中：绿色强调，更鲜活 */
.meal-item-ordering {
  background-color: #fff;
  border-left-color: #4CAF50;
  box-shadow: 0 2rpx 12rpx rgba(76, 175, 80, 0.15);
}

.meal-item-ordering .meal-name {
  color: #1A1A1A;
}

/* 已收单：灰色调，视觉弱化 */
.meal-item-closed {
  background-color: #F5F5F5;
  border-left-color: #9E9E9E;
}

.meal-item-closed .meal-name {
  color: #757575;
}

.meal-item-closed .meal-time:not(.meal-time--scheduled),
.meal-item-closed .meal-dishes {
  color: #9E9E9E;
}

.meal-info {
  margin-bottom: 20rpx;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* 餐名进一步加大 */
.meal-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #1A1A1A;
  flex: 1;
}

.meal-sections {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-section {
  background: transparent;
}

.meal-section__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 12rpx;
}

.meal-section__header:active {
  opacity: 0.85;
}

.meal-section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2e7d32;
}

.meal-section__arrow {
  font-size: 24rpx;
  color: #81c784;
}

.meal-section__body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.meal-section__empty {
  font-size: 26rpx;
  color: #999;
  padding: 24rpx 16rpx;
  text-align: center;
}

.history-loading,
.history-end {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  padding: 24rpx 0 32rpx;
}

.history-end {
  color: #81c784;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-ordering {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  font-weight: 600;
}

.status-closed {
  background-color: #E0E0E0;
  color: #757575;
}

.meal-time {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

/* 用餐时间：黑色（与发起时间灰色区分；已收单卡片也保持黑色） */
.meal-time.meal-time--scheduled {
  color: #000000;
}

.meal-dishes {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 操作按钮 -- keep themed gradients for personality */
.meal-actions {
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #C8E6C9;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
  border: none;
  color: #fff;
}

.btn-edit {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
}

.btn-close {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.btn-order {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.btn-view {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  color: #1A1A1A;
}

.btn-reopen {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  color: #1A1A1A;
}

.btn-share {
  background: linear-gradient(135deg, #E53935 0%, #ee5a6f 100%);
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.3);
}

.action-btn::after {
  border: none;
}
