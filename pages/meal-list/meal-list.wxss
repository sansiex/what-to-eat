/* pages/meal-list/meal-list.wxss */
.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* 顶部排序：左侧下拉 */
.meal-list-toolbar {
  display: flex;
  flex-direction: row;
  justify-content: flex-start;
  align-items: center;
  margin-bottom: 16rpx;
}

.meal-sort-picker {
  display: inline-flex;
  flex-direction: row;
  align-items: center;
  gap: 8rpx;
  max-width: 100%;
  padding: 12rpx 20rpx;
  font-size: 26rpx;
  color: #2e7d32;
  font-weight: 600;
  background: #fff;
  border: 1rpx solid #c8e6c9;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.meal-sort-picker__text {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: left;
}

.meal-sort-picker__caret {
  flex-shrink: 0;
  font-size: 18rpx;
  color: #81c784;
  line-height: 1;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 40rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-subtext {
  font-size: 28rpx;
  color: #999;
}

/* 点餐列表 */
.meal-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 点餐中与已收单共用卡片样式，仅右上角状态标签区分 */
.meal-item {
  border-radius: 16rpx;
  padding: 30rpx;
  background-color: #fff;
  border-left: 6rpx solid #4caf50;
  box-shadow: 0 2rpx 12rpx rgba(76, 175, 80, 0.15);
  cursor: pointer;
  box-sizing: border-box;
}

.meal-info {
  margin-bottom: 20rpx;
}

.meal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

/* 餐名进一步加大 */
.meal-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #1A1A1A;
  flex: 1;
}

.meal-sections {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.meal-section {
  background: transparent;
}

.meal-section__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 12rpx;
}

.meal-section__header:active {
  opacity: 0.85;
}

.meal-section__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #2e7d32;
}

.meal-section__arrow {
  font-size: 24rpx;
  color: #81c784;
}

.meal-section__body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.meal-section__empty {
  font-size: 26rpx;
  color: #999;
  padding: 24rpx 16rpx;
  text-align: center;
}

.history-end {
  text-align: center;
  font-size: 26rpx;
  color: #81c784;
  padding: 24rpx 0 32rpx;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-ordering {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
  color: #fff;
  font-weight: 600;
}

.status-closed {
  background-color: #E0E0E0;
  color: #757575;
}

.meal-time {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 8rpx;
}

/* 按用餐时间排列：用餐时间黑色并加大 */
.meal-time.meal-time--scheduled {
  color: #000000;
}

.meal-item--sort-scheduled .meal-time.meal-time--scheduled {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.45;
}

/* 按发起时间排列：发起时间在前、黑、大；用餐时间灰 */
.meal-item--sort-created .meal-time--created-lead {
  font-size: 32rpx;
  font-weight: 600;
  color: #000000;
  line-height: 1.45;
}

.meal-item--sort-created .meal-time--scheduled-muted {
  color: #888888;
  font-size: 26rpx;
  font-weight: 400;
}

.meal-dishes {
  display: block;
  font-size: 26rpx;
  color: #666;
}

/* 操作按钮 -- keep themed gradients for personality */
.meal-actions {
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid #C8E6C9;
  padding-top: 20rpx;
}

.action-btn {
  flex: 1;
  font-size: 28rpx;
  padding: 16rpx 0;
  border-radius: 8rpx;
  border: none;
  color: #fff;
}

.btn-edit {
  background: linear-gradient(135deg, #66BB6A 0%, #81C784 100%);
}

.btn-close {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.btn-order {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.btn-view {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  color: #1A1A1A;
}

.btn-reopen {
  background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
  color: #1A1A1A;
}

.btn-share {
  background: linear-gradient(135deg, #E53935 0%, #ee5a6f 100%);
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.3);
}

.action-btn::after {
  border: none;
}
