<!-- pages/meal-list/meal-list.wxml -->
<view class="container">
  <kitchen-switcher id="kitchenSwitcher" bind:kitchenchange="onKitchenChange" />

  <!-- 空状态 -->
  <view wx:if="{{meals.length === 0}}" class="empty-state">
    <text class="empty-text">暂无点餐记录</text>
    <text class="empty-subtext">点击底部"开始点餐"发起新的点餐</text>
  </view>

  <!-- 点餐列表 -->
  <view wx:else class="meal-list">
    <view wx:for="{{meals}}" wx:key="id" class="meal-item">
      <!-- 点餐信息 -->
      <view class="meal-info">
        <view class="meal-header">
          <text class="meal-name">{{item.name}}</text>
          <view class="status-badge {{item.status === 'ordering' ? 'status-ordering' : 'status-closed'}}">
            {{item.status === 'ordering' ? '点餐中' : '已收单'}}
          </view>
        </view>
        <text wx:if="{{!item.isCreator}}" class="meal-time">发起人：{{item.creatorName || '未知'}}</text>
        <text class="meal-time">发起时间：{{item.formattedCreatedAt}}</text>
        <text class="meal-dishes">菜品数：{{item.dishCount || 0}} 道</text>
      </view>

      <!-- 操作按钮 -->
      <view class="meal-actions">
        <!-- 点餐中状态：显示编辑、收单、点餐、分享按钮 -->
        <block wx:if="{{item.status === 'ordering'}}">
          <button wx:if="{{item.isCreator}}" class="action-btn btn-edit" bindtap="editMeal" data-id="{{item.id}}">编辑</button>
          <button wx:if="{{item.isCreator}}" class="action-btn btn-close" bindtap="closeMeal" data-id="{{item.id}}">收单</button>
          <button class="action-btn btn-order" bindtap="goOrder" data-id="{{item.id}}">点餐</button>
          <button wx:if="{{item.isCreator}}" class="action-btn btn-share" open-type="share" data-id="{{item.id}}" data-name="{{item.name}}">分享</button>
        </block>
        <!-- 已收单状态：显示查看、恢复点餐按钮 -->
        <block wx:else>
          <button class="action-btn btn-view" bindtap="viewMeal" data-id="{{item.id}}">查看</button>
          <button wx:if="{{item.isCreator}}" class="action-btn btn-reopen" bindtap="reopenMeal" data-id="{{item.id}}">恢复点餐</button>
        </block>
      </view>
    </view>
  </view>
</view>