<!-- pages/meal-list/meal-list.wxml -->
<view class="container">

  <view class="meal-list-toolbar">
    <picker
      mode="selector"
      range="{{sortModePickerRange}}"
      value="{{sortModeIndex}}"
      bindchange="onSortModeChange"
    >
      <view class="meal-sort-picker">
        <text class="meal-sort-picker__text">{{sortModePickerDisplay}}</text>
        <text class="meal-sort-picker__caret">▼</text>
      </view>
    </picker>
  </view>

  <view wx:if="{{listLoading}}" class="list-loading">
    <view class="list-loading-spinner" />
    <text class="list-loading-text">加载中...</text>
  </view>

  <view wx:elif="{{!hasAnyMeal}}" class="empty-state">
    <text class="empty-text">暂无点餐记录</text>
    <text class="empty-subtext">点击底部"开始点餐"发起新的点餐</text>
  </view>

  <view wx:else class="meal-sections">

    <view
      wx:for="{{mealSections}}"
      wx:for-item="sec"
      wx:key="key"
      class="meal-section {{sec.isHistory ? 'meal-section--history' : ''}}"
    >
      <view class="meal-section__header" bindtap="toggleSection" data-key="{{sec.key}}">
        <text class="meal-section__title">{{sec.title}}（{{sec.count}}）</text>
        <text class="meal-section__arrow">{{sec.expanded ? '▼' : '▶'}}</text>
      </view>
      <view wx:if="{{sec.expanded}}" class="meal-section__body">
        <view wx:if="{{sec.list.length === 0 && !(sec.isHistory && historyLoading)}}" class="meal-section__empty">{{sec.emptyText}}</view>
        <view
          wx:for="{{sec.list}}"
          wx:for-item="meal"
          wx:key="id"
          class="meal-item {{sortMode === 'scheduled' ? 'meal-item--sort-scheduled' : 'meal-item--sort-created'}}"
          bindtap="goMealDetail"
          data-id="{{meal.id}}"
        >
          <view class="meal-info">
            <view class="meal-header">
              <text class="meal-name">{{meal.name}}</text>
              <view class="status-badge {{meal.status === 'ordering' ? 'status-ordering' : 'status-closed'}}">
                {{meal.status === 'ordering' ? '点餐中' : '已收单'}}
              </view>
            </view>
            <block wx:if="{{sortMode === 'scheduled'}}">
              <text wx:if="{{meal.scheduledMealDisplay}}" class="meal-time meal-time--scheduled">用餐时间：{{meal.scheduledMealDisplay}}</text>
              <text class="meal-time">发起时间：{{meal.createdAtDisplay}}</text>
            </block>
            <block wx:else>
              <text class="meal-time meal-time--created-lead">发起时间：{{meal.createdAtDisplay}}</text>
              <text wx:if="{{meal.scheduledMealDisplay}}" class="meal-time meal-time--scheduled-muted">用餐时间：{{meal.scheduledMealDisplay}}</text>
            </block>
            <text wx:if="{{meal.status === 'closed'}}" class="meal-dishes">已点菜品数：{{meal.orderedDishCount || 0}} 道</text>
          </view>
        </view>
        <view wx:if="{{sec.isHistory && historyLoading}}" class="list-loading list-loading--inline">
          <view class="list-loading-spinner list-loading-spinner--sm" />
          <text class="list-loading-text">加载中...</text>
        </view>
        <view wx:if="{{sec.isHistory && sec.expanded && historyNoMore && sec.list.length > 0}}" class="history-end">已经到底啦~</view>
      </view>
    </view>

  </view>
</view>
